PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/civic-connect
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173
ALLOW_ADMIN_REGISTRATION=false
FALSE_COMPLAINT_SUSPENSION_THRESHOLD=3

# Cloudinary image storage
CLOUDINARY_CLOUD_NAME=demo-cloud-nameesfagha
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=cloudinary-example-secret

# Development email provider (Mailtrap SMTP)
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=mailtrap-example-user
MAILTRAP_PASS=mailtrap-example-pass
MAILTRAP_SENDER_EMAIL=no-reply@civicconnect.local

# Production email provider (Resend)
RESEND_API_KEY=re_example_resend_api_key
RESEND_FROM_EMAIL=Civic Connect <notifications@example.com>

